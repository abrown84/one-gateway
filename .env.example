# Required: your OpenClaw gateway token
# Find it in your openclaw.json → gateway.auth.token
ONCE_GATEWAY_TOKEN=replace_me

# Gateway URL (default: http://127.0.0.1:18789)
ONCE_GATEWAY_URL=http://127.0.0.1:18789

# Model to use (default: openclaw — lets OpenClaw route internally)
ONCE_GATEWAY_MODEL=openclaw

# Optional: comma-separated fallback models
# ONCE_GATEWAY_FALLBACKS=openclaw:main

# Optional: target a specific OpenClaw agent
ONCE_GATEWAY_AGENT=main

# Tuning (optional)
ONCE_GATEWAY_TEMPERATURE=0.2
ONCE_GATEWAY_MAX_TOKENS=500
ONCE_GATEWAY_TIMEOUT_MS=45000
